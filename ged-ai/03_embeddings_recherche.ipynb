   "source": [
    "# 03_embeddings_recherche.ipynb\n",
    "Génération d'embeddings avec sentence-transformers et recherche par similarité cosinus.\n",
    "Export embeddings dans ged-ai/artifacts/ (embeddings.npy + meta csv) pour usage en prod (pgvector compatible).\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from time import time\n",
    "from utils import ARTIFACTS_DIR, save_embeddings, load_documents_csv\n",
    "\n",
    "# Charger documents extraits\n",
    "df = None\n",
    "try:\n",
    "    df = load_documents_csv('documents_extraits.csv')\n",
    "except Exception as e:\n",
    "    raise SystemExit('documents_extraits.csv manquant — exécutez 01_extraction_texte')\n",
    "\n",
    "# Load sentence-transformers model\n",
    "try:\n",
    "    from sentence_transformers import SentenceTransformer\n",
    "    model = SentenceTransformer('paraphrase-multilingual-MiniLM-L12-v2')\n",
    "except Exception as e:\n",
    "    raise SystemExit('Veuillez installer sentence-transformers: pip install sentence-transformers')\n",
    "\n",
    "texts = df['texte_nettoye'].fillna('').astype(str).tolist()\n",
    "ids = df['id'].tolist() if 'id' in df.columns else list(range(len(texts)))\n",
    "print('Encoding', len(texts), 'documents')\n",
    "t0 = time()\n",
    "embeddings = model.encode(texts, show_progress_bar=True, convert_to_numpy=True)\n",
    "t1 = time()\n",
    "print('Encoded in', t1-t0, 's, dim=', embeddings.shape[1])\n",
    "\n",
    "# Save embeddings and meta\n",
    "paths = save_embeddings(embeddings, ids, basename='embeddings')\n",
    "print('Saved embeddings to', paths)\n",
    "\n",
    "# Simple search function using cosine similarity\n",
    "def search(query: str, top_k: int = 5):\n",
    "    q_emb = model.encode([query], convert_to_numpy=True)[0]\n",
    "    # cosine similarity via dot / norms\n",
    "    import numpy as _np\n",
    "    dots = embeddings @ q_emb\n",
    "    norms = _np.linalg.norm(embeddings, axis=1) * _np.linalg.norm(q_emb)\n",
    "    sims = dots / (norms + 1e-12)\n",
    "    idx = sims.argsort()[::-1][:top_k]\n",
    "    results = [(ids[i], float(sims[i]), texts[i][:400]) for i in idx]\n",
    "    return results\n",
    "\n",
    "# Test queries réalistes\n",
    "queries = ['procédure sécurité incendie', 'contrat prestataire technique']\n",
    "for q in queries:\n",
    "    print('\nQuery:', q)\n",
    "    for doc_id, score, snippet in search(q, top_k=5):\n",
    "        print(f"{doc_id} — {score:.4f} — {snippet[:120].replace('\n',' ')}")\n"
   ]
  }
