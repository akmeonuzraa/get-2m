    "# 02_classification.ipynb\n",
    "TF-IDF vectorization and comparison of KNN, RandomForest, XGBoost.\n",
    "Export best_classifier.joblib and tfidf_vectorizer.joblib to ged-ai/artifacts/.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os, time\n",
    "import pandas as pd\n",
    "from utils import ARTIFACTS_DIR, load_documents_csv\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.metrics import make_scorer, f1_score\n",
    "import joblib\n",
    "\n",
    "# Charger le CSV produit par le notebook 01\n",
    "df = None\n",
    "try:\n",
    "    df = load_documents_csv('documents_extraits.csv')\n",
    "except Exception as e:\n",
    "    print('Erreur: impossible de charger documents_extraits.csv dans ged-ai/artifacts. Exécuter 01_extraction_texte d'abord.')\n",
    "\n",
    "# ATTENTION: pour la classification il faut une colonne 'label' dans le CSV.\n",
    "# Si le jeu de données n'a pas de labels, créer une colonne label manuellement pour tester.\n",
    "if df is None:\n",
    "    raise SystemExit('documents_extraits.csv absent')\n",
    "if 'label' not in df.columns:\n",
    "    print('Aucune colonne "label" détectée. Ajoutez une colonne label au CSV pour entraîner.')\n",
    "\n",
    "# Vectorisation TF-IDF\n",
    "tfidf = TfidfVectorizer(ngram_range=(1,2), max_features=300)\n",
    "X = tfidf.fit_transform(df['texte_nettoye'].fillna(''))\n",
    "y = df['label'] if 'label' in df.columns else pd.Series(['unknown']*len(df))\n",
    "\n",
    "# Classifiers to compare\n",
    "clfs = {\n",
    "    'knn': KNeighborsClassifier(n_neighbors=5),\n",
    "    'rf': RandomForestClassifier(n_estimators=100, random_state=42)\n",
    "}\n",
    "# Try to add XGBoost if available\n",
    "try:\n",
    "    from xgboost import XGBClassifier\n",
    "    clfs['xgb'] = XGBClassifier(use_label_encoder=False, eval_metric='logloss', random_state=42)\n",
    "except Exception:\n",
    "    print('xgboost non installé — skipped. (pip install xgboost)')\n",
    "\n",
    "# Evaluate with StratifiedKFold\n",
    "skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
    "scorer = make_scorer(f1_score, average='weighted')\n",
    "results = {}\n",
    "for name, clf in clfs.items():\n",
    "    print('Evaluating', name)\n",
    "    try:\n",
    "        scores = cross_val_score(clf, X, y, cv=skf, scoring=scorer, n_jobs=-1)\n",
    "        results[name] = scores.mean()\n",
    "        print(f'{name} mean F1-weighted: {scores.mean():.4f}')\n",
    "    except Exception as e:\n",
    "        print('Failed to evaluate', name, e)\n",
    "\n",
    "# Select best model\n",
    "if results:\n",
    "    best_name = max(results, key=results.get)\n",
    "    print('Best:', best_name, results[best_name])\n",
    "    best_clf = clfs[best_name]\n",
    "    # Fit on full dataset and save\n",
    "    best_clf.fit(X, y)\n",
    "    model_path = os.path.join(ARTIFACTS_DIR, 'best_classifier.joblib')\n",
    "    vect_path = os.path.join(ARTIFACTS_DIR, 'tfidf_vectorizer.joblib')\n",
    "    joblib.dump(best_clf, model_path)\n",
    "    joblib.dump(tfidf, vect_path)\n",
    "    print('Saved', model_path, vect_path)\n",
    "else:\n",
    "    print('No results: ensure labels exist and there are at least 2 classes.')\n"
   ]
  }
