   "source": [
    "# 01_extraction_texte.ipynb\n",
    "Extraction de texte depuis PDF (pdfplumber) et DOCX (python-docx).\n",
    "Nettoyage simple et export CSV pour réutilisation.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Imports\n",
    "import os, re, sys\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "import pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "# Optional imports with helpful message\n",
    "try:\n",
    "    import pdfplumber\n",
    "except Exception as e:\n",
    "    print(\"Missing pdfplumber: pip install pdfplumber\")\n",
    "try:\n",
    "    import docx\n",
    "except Exception as e:\n",
    "    print(\"Missing python-docx: pip install python-docx\")\n",
    "\n",
    "from utils import ARTIFACTS_DIR, save_dataframe\n",
    "\n",
    "def extract_text_pdf(path: str) -> str:\n",
    "    text_parts = []\n",
    "    try:\n",
    "        with pdfplumber.open(path) as pdf:\n",
    "            for page in pdf.pages:\n",
    "                text_parts.append(page.extract_text() or '')\n",
    "    except Exception as e:\n",
    "        print(f'Error reading PDF {path}: {e}')\n",
    "    return "\n".join(text_parts)\n",
    "\n",
    "def extract_text_docx(path: str) -> str:\n",
    "    text_parts = []\n",
    "    try:\n",
    "        doc = docx.Document(path)\n",
    "        for para in doc.paragraphs:\n",
    "            text_parts.append(para.text)\n",
    "    except Exception as e:\n",
    "        print(f'Error reading DOCX {path}: {e}')\n",
    "    return "\n".join(text_parts)\n",
    "\n",
    "def clean_text(text: str) -> str:\n",
    "    if not isinstance(text, str):\n",
    "        return ''\n",
    "    # Normalize whitespace\n",
    "    t = text.replace('\r', '\n')\n",
    "    t = re.sub('\n{2,}', '\n\n', t)\n",
    "    t = re.sub('[ \t]+', ' ', t)\n",
    "    # Remove repeated headers/footers heuristics: remove very short repeated lines\n",
    "    lines = [ln.strip() for ln in t.splitlines() if ln.strip()]\n",
    "    # drop lines that are repeated more than 3 times across document (likely header/footer)\n",
    "    freq = defaultdict(int)\n",
    "    for ln in lines:\n",
    "        freq[ln] += 1\n",
    "    filtered = [ln for ln in lines if freq.get(ln,0) <= 3]\n",
    "    out = '\n'.join(filtered)\n",
    "    # ensure valid utf-8 replacement for bad chars\n",
    "    out = out.encode('utf-8', 'replace').decode('utf-8')\n",
    "    return out.strip()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Parcourir un dossier et extraire le texte\n",
    "from pathlib import Path\n",
    "\n",
    "def process_folder(input_dir: str, out_csv_name: str = 'documents_extraits.csv'):\n",
    "    input_dir = Path(input_dir)\n",
    "    records = []\n",
    "    for p in tqdm(list(input_dir.glob('**/*'))):\n",
    "        if p.is_file() and p.suffix.lower() in ['.pdf', '.docx']:\n",
    "            raw = ''\n",
    "            if p.suffix.lower() == '.pdf':\n",
    "                raw = extract_text_pdf(str(p))\n",
    "            elif p.suffix.lower() == '.docx':\n",
    "                raw = extract_text_docx(str(p))\n",
    "            clean = clean_text(raw)\n",
    "            nb_mots = len(clean.split())\n",
    "            records.append({'id': str(p.relative_to(input_dir)), 'texte_brut': raw, 'texte_nettoye': clean, 'nb_mots': nb_mots})\n",
    "    df = pd.DataFrame(records)\n",
    "    out_path = save_dataframe(df, out_csv_name)\n",
    "    print('Saved', out_path)\n",
    "    return df\n",
    "\n",
    "# Exemple d'utilisation: modifier la variable ci-dessous puis exécuter cette cellule\n",
    "# input_dir = r'C:\\chemin\\vers\\docs'\n",
    "# df = process_folder(input_dir)\n",
    "\n",
    "print('Cell ready. Set input_dir and call process_folder(input_dir)')\n"
   ]
  },
